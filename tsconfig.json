{
  "compilerOptions": {
    "strict": true,
    "lib": ["dom", "es2020"],
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": [
    "types/**/*.ts",
    "background/**/*.ts",
    "content/**/*.ts",
    "utils/**/*.ts",
    "mock/**/*.ts"
  ]
}
